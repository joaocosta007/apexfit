generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  TRAINER
  STUDENT
}

enum PlanType {
  NORMAL
  LOW_VOLUME
  STRENGTH
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  trainerStudents    StudentTrainer[]      @relation("TrainerStudents")
  studentTrainers    StudentTrainer[]      @relation("StudentTrainers")
  studentPlans       WorkoutPlan[]         @relation("StudentWorkoutPlans")
  trainerPlans       WorkoutPlan[]         @relation("TrainerWorkoutPlans")
  workoutLogs        WorkoutLog[]
  studentAssessments PhysicalAssessment[]  @relation("StudentAssessments")
  trainerAssessments PhysicalAssessment[]  @relation("TrainerAssessments")
  inviteTokens       InviteToken[]

  @@index([role])
  @@map("users")
}

model StudentTrainer {
  studentId String   @map("student_id")
  trainerId String   @map("trainer_id")
  createdAt DateTime @default(now()) @map("created_at")

  student User @relation("StudentTrainers", fields: [studentId], references: [id], onDelete: Cascade)
  trainer User @relation("TrainerStudents", fields: [trainerId], references: [id], onDelete: Cascade)

  @@id([studentId, trainerId])
  @@index([trainerId])
  @@map("student_trainer_relations")
}

model WorkoutPlan {
  id           String   @id @default(cuid())
  studentId    String   @map("student_id")
  trainerId    String   @map("trainer_id")
  planName     String   @map("plan_name")
  trainingDays Json     @map("training_days")
  planType     PlanType @default(NORMAL) @map("plan_type")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student User           @relation("StudentWorkoutPlans", fields: [studentId], references: [id], onDelete: Cascade)
  trainer User           @relation("TrainerWorkoutPlans", fields: [trainerId], references: [id], onDelete: Cascade)
  splits  WorkoutSplit[]

  @@index([studentId, isActive])
  @@index([trainerId])
  @@map("workout_plans")
}

model WorkoutSplit {
  id        String   @id @default(cuid())
  planId    String   @map("plan_id")
  splitName String   @map("split_name")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plan      WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@index([planId, sortOrder])
  @@map("workout_splits")
}

model Exercise {
  id       String   @id @default(cuid())
  splitId   String  @map("split_id")
  catalogId String? @map("catalog_id")
  name      String
  sets      Int
  reps     Int
  loadKg   Float    @map("load_kg")
  restTime String   @map("rest_time")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  split       WorkoutSplit @relation(fields: [splitId], references: [id], onDelete: Cascade)
  workoutLogs WorkoutLog[]

  @@index([splitId])
  @@map("exercises")
}

model WorkoutLog {
  id              String   @id @default(cuid())
  studentId       String   @map("student_id")
  exerciseId      String   @map("exercise_id")
  completedLoadKg Float    @map("completed_load_kg")
  completed       Boolean  @default(true)
  date            DateTime @default(now())

  student  User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([studentId, exerciseId, date])
  @@map("workout_logs")
}

model PhysicalAssessment {
  id          String   @id @default(cuid())
  studentId   String   @map("student_id")
  trainerId   String   @map("trainer_id")
  date        DateTime @default(now())
  weight      Float?
  bodyFat     Float?   @map("body_fat")
  chest       Float?
  waist       Float?
  abdomen     Float?
  hip         Float?
  rightArm    Float?   @map("right_arm")
  leftArm     Float?   @map("left_arm")
  rightThigh  Float?   @map("right_thigh")
  leftThigh   Float?   @map("left_thigh")
  rightCalf   Float?   @map("right_calf")
  leftCalf    Float?   @map("left_calf")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  student User @relation("StudentAssessments", fields: [studentId], references: [id], onDelete: Cascade)
  trainer User @relation("TrainerAssessments", fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([studentId, date])
  @@map("physical_assessments")
}

model InviteToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  trainerId String   @map("trainer_id")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("invite_tokens")
}